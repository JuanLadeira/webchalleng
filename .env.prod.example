# ── Domínio e TLS ────────────────────────────────────────────────────────────
DOMAIN=seu-dominio.com
ACME_EMAIL=seu@email.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false

# ── Banco de dados ───────────────────────────────────────────────────────────
POSTGRES_USER=pguser
POSTGRES_PASSWORD=senha-forte-aqui
POSTGRES_DB=meetings
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=chave-secreta-longa-e-aleatoria-aqui
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── SMTP (e-mail real em produção) ────────────────────────────────────────────
SMTP_HOST=smtp.seuservidor.com
SMTP_PORT=587
SMTP_FROM=noreply@seu-dominio.com
SMTP_USER=seu@email.com
SMTP_PASSWORD=senha-smtp
SMTP_TLS=true

# ── Celery ────────────────────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_SECONDS=10
